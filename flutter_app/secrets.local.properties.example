GEMINI_API_KEY=your-gemini-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Supabase project (Project Settings -> API in the dashboard). The anon key
# below is the "publishable" key — it's meant to be public, not a secret.
SUPABASE_URL=https://oxfnrsjskdjbroekxdco.supabase.co
SUPABASE_ANON_KEY=your-supabase-publishable-key-here

# Google Sign-In OAuth client IDs (Google Cloud Console). See
# BUILD_FLUTTER_TO_IPHONE.md "Google Sign-In one-time setup" for exactly how
# to create these. Leave blank and Google sign-in shows a friendly
# "not configured yet" message instead of crashing.
GOOGLE_IOS_CLIENT_ID=your-ios-oauth-client-id-here
GOOGLE_WEB_CLIENT_ID=your-web-oauth-client-id-here

# RevenueCat public SDK keys (RevenueCat dashboard -> Project Settings -> API keys).
# Leave blank and the app reports "not configured" instead of crashing.
REVENUECAT_IOS_KEY=your-revenuecat-ios-sdk-key-here
REVENUECAT_ANDROID_KEY=your-revenuecat-android-sdk-key-here
